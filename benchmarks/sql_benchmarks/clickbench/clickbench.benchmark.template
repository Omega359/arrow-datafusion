name Q${QUERY_NUMBER_PADDED}
group clickbench

init sql_benchmarks/clickbench/init/set_config.sql

echo Loading clickbench ${CLICKBENCH_TYPE:-single} hits table

load sql_benchmarks/clickbench/init/load-${CLICKBENCH_TYPE:-single}.sql

assert I
SELECT COUNT(*) > 0 from hits;
----
true

run sql_benchmarks/clickbench/queries/q${QUERY_NUMBER_PADDED}.sql

result sql_benchmarks/clickbench/results/${CLICKBENCH_TYPE:-single}/q${QUERY_NUMBER_PADDED}.csv
