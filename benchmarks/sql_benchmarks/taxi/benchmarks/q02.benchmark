
name Q02
group taxi

echo Loading taxi data

load sql_benchmarks/taxi/init/load.sql

assert I
SELECT COUNT(*) > 0 from trips;
----
true

run
SELECT passenger_count, ROUND(AVG(total_amount), 10) as avg_total_amount FROM trips GROUP BY passenger_count order by passenger_count, avg_total_amount;

result sql_benchmarks/taxi/results/q02.csv
