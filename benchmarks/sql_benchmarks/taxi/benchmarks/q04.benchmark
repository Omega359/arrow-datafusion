
name Q04
group taxi

echo Loading taxi data

load sql_benchmarks/taxi/init/load.sql

assert I
SELECT COUNT(*) > 0 from trips;
----
true

run
SELECT passenger_count, DATE_PART('year', pickup_datetime) AS year, ROUND(trip_distance) AS distance, COUNT(*) as count FROM trips GROUP BY passenger_count, year, distance ORDER BY passenger_count, year, distance, count;

result sql_benchmarks/taxi/results/q04.csv


