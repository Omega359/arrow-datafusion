
name Q03
group taxi

echo Loading taxi data

load sql_benchmarks/taxi/init/load.sql

assert I
SELECT COUNT(*) > 0 from trips;
----
true

run
SELECT passenger_count, DATE_PART('year', pickup_datetime) AS year, COUNT(*) as count, FROM trips GROUP BY passenger_count, year ORDER BY passenger_count, year;

result sql_benchmarks/taxi/results/q03.csv
